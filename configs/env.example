# =============================================================================
# HabitPal Backend -- Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Do NOT commit .env files with real secrets to version control.
# =============================================================================

# --- Server ---
# Port the backend HTTP server listens on.
PORT=8080

# --- Database ---
# PostgreSQL connection string.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=disable
DATABASE_URL=postgres://habitpal:habitpal_dev@localhost:5432/habitpal?sslmode=disable

# --- Authentication ---
# Secret key used to sign JWT tokens. Use a strong random string in production.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-strong-random-string

# How long JWT tokens remain valid, in hours.
JWT_EXPIRATION_HOURS=24
